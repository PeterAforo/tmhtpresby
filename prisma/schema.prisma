generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth.js / Auth.js) ────────────────────────────────
model User {
  id             String    @id @default(cuid())
  firstName      String
  lastName       String
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  phone          String?
  dateOfBirth    DateTime?
  role           String    @default("visitor") // super_admin, pastor, ministry_leader, member, visitor
  isMinor        Boolean   @default(false)
  parentalConsent Boolean  @default(false)
  ministryGroup  String?   // auto-assigned based on age: children, youth, young_adult, adult, senior
  bio            String?
  isActive       Boolean   @default(true)
  accounts          Account[]
  sessions          Session[]
  posts             DiscussionPost[]
  replies           DiscussionReply[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  conversationParticipants ConversationParticipant[]
  messages          Message[]
  ministryGroupMemberships MinistryGroupMember[]
  hostedMeetings    VideoMeeting[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Discussion / Community ──────────────────────────────────────
model DiscussionPost {
  id        String            @id @default(cuid())
  title     String
  content   String
  category  String            @default("general") // general, prayer, testimony, question, announcement
  isPinned  Boolean           @default(false)
  isFlagged Boolean           @default(false)
  authorId  String
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   DiscussionReply[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([authorId])
  @@index([category])
  @@index([createdAt(sort: Desc)])
  @@map("discussion_posts")
}

model DiscussionReply {
  id        String   @id @default(cuid())
  content   String
  isFlagged Boolean  @default(false)
  postId    String
  post      DiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
  @@map("discussion_replies")
}

// ─── Contact Form Submissions ───────────────────────────────────
model Contact {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@map("contacts")
}

// ─── Newsletter Subscribers ─────────────────────────────────────
model NewsletterSubscriber {
  id           String    @id @default(cuid())
  email        String    @unique
  confirmedAt  DateTime?
  unsubscribed Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@map("newsletter_subscribers")
}

// ─── Speakers ───────────────────────────────────────────────────
model Speaker {
  id        String   @id @default(cuid())
  name      String
  title     String?  // e.g. "Rev. Dr.", "Pastor"
  bio       String?
  imageUrl  String?
  sermons   Sermon[]
  createdAt DateTime @default(now())

  @@map("speakers")
}

// ─── Sermon Series ──────────────────────────────────────────────
model SermonSeries {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  imageUrl    String?
  sermons     Sermon[]
  createdAt   DateTime @default(now())

  @@map("sermon_series")
}

// ─── Sermons ────────────────────────────────────────────────────
model Sermon {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  scripture    String?
  description  String?
  content      String?       // Full sermon text/transcript for reading
  date         DateTime
  duration     Int?          // duration in seconds
  mediaType    String        @default("video") // video, audio, text
  videoUrl     String?
  audioUrl     String?
  thumbnailUrl String?
  youtubeId    String?
  documentUrl  String?       // PDF or document download link
  published    Boolean       @default(true)
  viewCount    Int           @default(0)
  speakerId    String
  speaker      Speaker       @relation(fields: [speakerId], references: [id])
  seriesId     String?
  series       SermonSeries? @relation(fields: [seriesId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([speakerId])
  @@index([seriesId])
  @@index([date(sort: Desc)])
  @@index([mediaType])
  @@map("sermons")
}

// ─── Donors ─────────────────────────────────────────────────────
model Donor {
  id               String     @id @default(cuid())
  email            String     @unique
  firstName        String?
  lastName         String?
  phone            String?
  stripeCustomerId String?    @unique
  donations        Donation[]
  createdAt        DateTime   @default(now())

  @@map("donors")
}

// ─── Donations ──────────────────────────────────────────────────
model Donation {
  id                String   @id @default(cuid())
  amount            Int      // amount in pesewas (smallest unit)
  currency          String   @default("GHS")
  fund              String   @default("general")
  frequency         String   @default("one-time") // one-time, monthly
  status            String   @default("pending")   // pending, completed, failed, refunded
  stripeSessionId   String?  @unique
  stripePaymentId   String?  @unique
  stripeSubId       String?  @unique
  receiptUrl        String?
  receiptSentAt     DateTime?
  donorId           String?
  donor             Donor?   @relation(fields: [donorId], references: [id])
  // Guest donor info (when not logged in)
  guestEmail        String?
  guestFirstName    String?
  guestLastName     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([donorId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("donations")
}

// ─── Events ─────────────────────────────────────────────────────
model Event {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String?
  location    String?     // Venue name/address
  latitude    Float?      // GPS latitude
  longitude   Float?      // GPS longitude
  category    String      @default("special") // worship, youth, women, men, prayer, outreach, conference, special, family
  imageUrl    String?     // Event image/artwork
  startDate   DateTime
  endDate     DateTime?
  startTime   String?     // e.g. "09:00"
  endTime     String?     // e.g. "17:00"
  capacity    Int?
  likes       Int         @default(0)
  isFeatured  Boolean     @default(false)
  published   Boolean     @default(true)
  rsvps       EventRsvp[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([startDate(sort: Asc)])
  @@index([category])
  @@map("events")
}

model EventRsvp {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  email     String
  phone     String?
  guests    Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())

  @@unique([eventId, email])
  @@map("event_rsvps")
}

// ─── News/Blog Posts ─────────────────────────────────────────────────
model BlogPost {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String        // HTML or markdown
  author      String
  category    String        @default("general")
  imageUrl    String?
  readTime    Int?          // minutes
  published   Boolean       @default(true)
  viewCount   Int           @default(0)
  likes       Int           @default(0)
  publishedAt DateTime      @default(now())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  comments    NewsComment[]
  ratings     NewsRating[]

  @@index([publishedAt(sort: Desc)])
  @@index([category])
  @@map("blog_posts")
}

model NewsComment {
  id          String    @id @default(cuid())
  content     String
  authorName  String
  authorEmail String
  isApproved  Boolean   @default(false)
  postId      String
  post        BlogPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([postId])
  @@index([isApproved])
  @@map("news_comments")
}

model NewsRating {
  id        String   @id @default(cuid())
  rating    Int      // 1-5 stars
  ipAddress String?
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, ipAddress])
  @@index([postId])
  @@map("news_ratings")
}

// ─── Gallery ────────────────────────────────────────────────────
model GalleryAlbum {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String?
  coverUrl    String?
  published   Boolean        @default(true)
  images      GalleryImage[]
  createdAt   DateTime       @default(now())

  @@map("gallery_albums")
}

model GalleryImage {
  id        String       @id @default(cuid())
  url       String
  caption   String?
  order     Int          @default(0)
  albumId   String
  album     GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([albumId])
  @@map("gallery_images")
}

// ─── Daily Devotionals ──────────────────────────────────────────
model Devotional {
  id              String   @id @default(cuid())
  title           String
  coverImage      String?  // Cover image URL
  scripture       String   // Scripture reference (e.g., "John 3:16")
  scriptureText   String?  @db.Text // Full scripture text
  content         String?  @db.Text // Main devotional content (optional now)
  prayer          String?  @db.Text // Prayer section
  keyNote         String?  @db.Text // Key takeaway/note
  author          String
  publishDate     DateTime @unique
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([publishDate(sort: Desc)])
  @@map("devotionals")
}

// ─── Prayer Requests ────────────────────────────────────────────
model PrayerRequest {
  id        String   @id @default(cuid())
  name      String
  email     String?
  request   String
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("prayer_requests")
}

// ─── Notifications ──────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("general") // general, event, sermon, blog, community, campaign
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Push Subscriptions ─────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Campaigns (Email/SMS/Push Blasts) ──────────────────────────
model Campaign {
  id          String    @id @default(cuid())
  title       String
  subject     String?   // email subject line
  content     String    // body text or HTML
  channel     String    @default("email") // email, sms, push
  audience    String    @default("all")   // all, members, visitors, ministry group name
  status      String    @default("draft") // draft, scheduled, sent, failed
  scheduledAt DateTime?
  sentAt      DateTime?
  sentCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("campaigns")
}

// ─── Analytics Page Views ───────────────────────────────────────
model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt(sort: Desc)])
  @@map("page_views")
}

// ─── Leadership Groups ─────────────────────────────────────────
// Groups: session, ministers, agents, administration, ministries, departments, committees
model LeadershipGroup {
  id          String               @id @default(cuid())
  name        String               // e.g. "Church Session", "Men's Ministry", "Finance Committee"
  slug        String               @unique
  type        String               // session, ministers, agents, administration, ministry, department, committee
  description String?
  imageUrl    String?
  order       Int                  @default(0)
  isActive    Boolean              @default(true)
  positions   LeadershipPosition[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([type])
  @@index([isActive])
  @@map("leadership_groups")
}

// ─── Leadership Positions ──────────────────────────────────────
// Defines positions within a group (e.g. "Chairman", "Secretary", "Treasurer")
model LeadershipPosition {
  id          String             @id @default(cuid())
  title       String             // e.g. "Chairman", "Secretary", "Youth Pastor"
  description String?
  order       Int                @default(0)
  groupId     String
  group       LeadershipGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  members     LeadershipMember[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([groupId])
  @@map("leadership_positions")
}

// ─── Leadership Members ────────────────────────────────────────
// Tracks current and past members in leadership positions
model LeadershipMember {
  id          String             @id @default(cuid())
  firstName   String
  lastName    String
  title       String?            // e.g. "Elder", "Rev.", "Deaconess"
  email       String?
  phone       String?
  imageUrl    String?
  bio         String?
  facebook    String?            // Facebook profile URL
  twitter     String?            // Twitter/X handle or URL
  instagram   String?            // Instagram handle or URL
  linkedin    String?            // LinkedIn profile URL
  whatsapp    String?            // WhatsApp number
  startDate   DateTime           // When they started in this position
  endDate     DateTime?          // Null if currently serving
  isCurrent   Boolean            @default(true)
  positionId  String
  position    LeadershipPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([positionId])
  @@index([isCurrent])
  @@index([startDate(sort: Desc)])
  @@map("leadership_members")
}

// =============================================================================
// Custom Pages (Page Builder)
// =============================================================================

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  content     Json?    // Page builder content blocks
  published   Boolean  @default(false)
  template    String   @default("default") // default, full-width, sidebar
  metaTitle   String?
  metaDesc    String?
  featuredImg String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@map("pages")
}

// Page Hero Settings
// =============================================================================

model PageHero {
  id            String   @id @default(cuid())
  pageSlug      String   @unique // e.g., "about", "about/church", "sermons", "contact"
  title         String?  // Optional override for page title
  subtitle      String?  // Optional override for subtitle
  backgroundUrl String?  // Background image URL
  overlayColor  String?  @default("rgba(12, 21, 41, 0.85)") // Dark overlay for text readability
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([pageSlug])
  @@map("page_heroes")
}

// =============================================================================
// Social/Community Features
// =============================================================================

// ─── Direct Messages ────────────────────────────────────────────────
model Conversation {
  id           String    @id @default(cuid())
  type         String    @default("direct") // direct, group
  name         String?   // For group conversations
  imageUrl     String?   // For group avatar
  participants ConversationParticipant[]
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("conversations")
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member") // admin, member
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime     @default(now())
  isMuted        Boolean      @default(false)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id             String       @id @default(cuid())
  content        String
  type           String       @default("text") // text, image, file, system
  fileUrl        String?
  fileName       String?
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  isEdited       Boolean      @default(false)
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt(sort: Desc)])
  @@map("messages")
}

// ─── Ministry Groups (for group messaging) ──────────────────────────
model MinistryGroup {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?
  imageUrl    String?
  isPrivate   Boolean             @default(false)
  members     MinistryGroupMember[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("ministry_groups")
}

model MinistryGroupMember {
  id        String        @id @default(cuid())
  groupId   String
  group     MinistryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String        @default("member") // admin, moderator, member
  joinedAt  DateTime      @default(now())

  @@unique([groupId, userId])
  @@index([userId])
  @@map("ministry_group_members")
}

// ─── Video Conferencing ─────────────────────────────────────────────
model VideoMeeting {
  id           String    @id @default(cuid())
  title        String
  description  String?
  roomId       String    @unique // External meeting room ID (e.g., Daily.co, Jitsi)
  hostId       String
  host         User      @relation(fields: [hostId], references: [id])
  scheduledAt  DateTime?
  startedAt    DateTime?
  endedAt      DateTime?
  isRecurring  Boolean   @default(false)
  maxParticipants Int?
  isPublic     Boolean   @default(false)
  ministrySlug String?   // Link to ministry if applicable
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([hostId])
  @@index([scheduledAt])
  @@map("video_meetings")
}

// ─── Church Projects ────────────────────────────────────────────────
model Project {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String
  content       String?   // Full project details (rich text)
  imageUrl      String?
  goalAmount    Float?    // Fundraising goal
  raisedAmount  Float     @default(0) // Amount raised so far
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("ongoing") // ongoing, completed, paused
  category      String    @default("general") // building, mission, community, education, etc.
  isFeatured    Boolean   @default(false)
  isPublished   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([isFeatured])
  @@map("projects")
}

// ─── Shop / E-commerce ────────────────────────────────────────────────
model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  products    Product[]
  createdAt   DateTime  @default(now())

  @@map("product_categories")
}

model Product {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  description     String?
  price           Int              // Price in pesewas (smallest currency unit)
  compareAtPrice  Int?             // Original price for showing discounts
  sku             String?          @unique
  stock           Int              @default(0)
  lowStockAlert   Int              @default(5)
  images          ProductImage[]
  categoryId      String?
  category        ProductCategory? @relation(fields: [categoryId], references: [id])
  ministryGroup   String?          // aged, men, women, young_adult, ypg, junior, choir, etc.
  ministrySlug    String?          // Link to specific ministry
  isFeatured      Boolean          @default(false)
  isActive        Boolean          @default(true)
  weight          Float?           // For shipping calculations
  dimensions      String?          // e.g., "10x5x3 cm"
  tags            String[]         // Array of tags for filtering
  orderItems      OrderItem[]
  cartItems       CartItem[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([categoryId])
  @@index([ministryGroup])
  @@index([isFeatured])
  @@index([isActive])
  @@map("products")
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  order     Int      @default(0)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model Cart {
  id        String     @id @default(cuid())
  sessionId String     @unique // For guest carts
  userId    String?    // For logged-in users
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([userId])
  @@map("carts")
}

model CartItem {
  id        String   @id @default(cuid())
  quantity  Int      @default(1)
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@map("cart_items")
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  status            String      @default("pending") // pending, processing, shipped, delivered, cancelled, refunded
  subtotal          Int         // In pesewas
  shippingCost      Int         @default(0)
  tax               Int         @default(0)
  total             Int
  currency          String      @default("GHS")
  // Customer info
  customerEmail     String
  customerFirstName String
  customerLastName  String
  customerPhone     String?
  userId            String?     // If logged in
  // Shipping address
  shippingAddress   String?
  shippingCity      String?
  shippingRegion    String?
  shippingCountry   String      @default("Ghana")
  // Payment
  paymentMethod     String?     // stripe, momo, cash
  paymentStatus     String      @default("pending") // pending, paid, failed, refunded
  stripeSessionId   String?     @unique
  stripePaymentId   String?
  // Tracking
  trackingNumber    String?
  shippedAt         DateTime?
  deliveredAt       DateTime?
  notes             String?
  items             OrderItem[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt(sort: Desc)])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  quantity    Int
  unitPrice   Int      // Price at time of order (in pesewas)
  totalPrice  Int
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  productName String   // Snapshot of product name
  productSku  String?  // Snapshot of SKU
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// =============================================================================
// Site Settings
// =============================================================================

model SiteSettings {
  id        String   @id @default("main")
  data      Json     // Store all settings as JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}
