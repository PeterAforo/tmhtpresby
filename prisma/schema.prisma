generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth.js / Auth.js) ────────────────────────────────
model User {
  id             String    @id @default(cuid())
  firstName      String
  lastName       String
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  image          String?
  phone          String?
  dateOfBirth    DateTime?
  role           String    @default("visitor") // super_admin, pastor, ministry_leader, member, visitor
  isMinor        Boolean   @default(false)
  parentalConsent Boolean  @default(false)
  ministryGroup  String?   // auto-assigned based on age: children, youth, young_adult, adult, senior
  bio            String?
  isActive       Boolean   @default(true)
  accounts          Account[]
  sessions          Session[]
  posts             DiscussionPost[]
  replies           DiscussionReply[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Discussion / Community ──────────────────────────────────────
model DiscussionPost {
  id        String            @id @default(cuid())
  title     String
  content   String
  category  String            @default("general") // general, prayer, testimony, question, announcement
  isPinned  Boolean           @default(false)
  isFlagged Boolean           @default(false)
  authorId  String
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies   DiscussionReply[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([authorId])
  @@index([category])
  @@index([createdAt(sort: Desc)])
  @@map("discussion_posts")
}

model DiscussionReply {
  id        String   @id @default(cuid())
  content   String
  isFlagged Boolean  @default(false)
  postId    String
  post      DiscussionPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([authorId])
  @@map("discussion_replies")
}

// ─── Contact Form Submissions ───────────────────────────────────
model Contact {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@map("contacts")
}

// ─── Newsletter Subscribers ─────────────────────────────────────
model NewsletterSubscriber {
  id           String    @id @default(cuid())
  email        String    @unique
  confirmedAt  DateTime?
  unsubscribed Boolean   @default(false)
  createdAt    DateTime  @default(now())

  @@map("newsletter_subscribers")
}

// ─── Speakers ───────────────────────────────────────────────────
model Speaker {
  id        String   @id @default(cuid())
  name      String
  title     String?  // e.g. "Rev. Dr.", "Pastor"
  bio       String?
  imageUrl  String?
  sermons   Sermon[]
  createdAt DateTime @default(now())

  @@map("speakers")
}

// ─── Sermon Series ──────────────────────────────────────────────
model SermonSeries {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  imageUrl    String?
  sermons     Sermon[]
  createdAt   DateTime @default(now())

  @@map("sermon_series")
}

// ─── Sermons ────────────────────────────────────────────────────
model Sermon {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  scripture    String?
  description  String?
  date         DateTime
  duration     Int?          // duration in seconds
  videoUrl     String?
  audioUrl     String?
  thumbnailUrl String?
  youtubeId    String?
  published    Boolean       @default(true)
  viewCount    Int           @default(0)
  speakerId    String
  speaker      Speaker       @relation(fields: [speakerId], references: [id])
  seriesId     String?
  series       SermonSeries? @relation(fields: [seriesId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([speakerId])
  @@index([seriesId])
  @@index([date(sort: Desc)])
  @@map("sermons")
}

// ─── Donors ─────────────────────────────────────────────────────
model Donor {
  id               String     @id @default(cuid())
  email            String     @unique
  firstName        String?
  lastName         String?
  phone            String?
  stripeCustomerId String?    @unique
  donations        Donation[]
  createdAt        DateTime   @default(now())

  @@map("donors")
}

// ─── Donations ──────────────────────────────────────────────────
model Donation {
  id                String   @id @default(cuid())
  amount            Int      // amount in pesewas (smallest unit)
  currency          String   @default("GHS")
  fund              String   @default("general")
  frequency         String   @default("one-time") // one-time, monthly
  status            String   @default("pending")   // pending, completed, failed, refunded
  stripeSessionId   String?  @unique
  stripePaymentId   String?  @unique
  stripeSubId       String?  @unique
  receiptUrl        String?
  receiptSentAt     DateTime?
  donorId           String?
  donor             Donor?   @relation(fields: [donorId], references: [id])
  // Guest donor info (when not logged in)
  guestEmail        String?
  guestFirstName    String?
  guestLastName     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([donorId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("donations")
}

// ─── Events ─────────────────────────────────────────────────────
model Event {
  id          String      @id @default(cuid())
  title       String
  slug        String      @unique
  description String?
  location    String?
  category    String      @default("special") // worship, youth, women, men, prayer, outreach, conference, special, family
  imageUrl    String?
  startDate   DateTime
  endDate     DateTime?
  startTime   String?     // e.g. "09:00"
  endTime     String?     // e.g. "17:00"
  capacity    Int?
  isFeatured  Boolean     @default(false)
  published   Boolean     @default(true)
  rsvps       EventRsvp[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([startDate(sort: Asc)])
  @@index([category])
  @@map("events")
}

model EventRsvp {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  email     String
  phone     String?
  guests    Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())

  @@unique([eventId, email])
  @@map("event_rsvps")
}

// ─── Blog Posts ─────────────────────────────────────────────────
model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   // HTML or markdown
  author      String
  category    String   @default("general")
  imageUrl    String?
  readTime    Int?     // minutes
  published   Boolean  @default(true)
  viewCount   Int      @default(0)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([publishedAt(sort: Desc)])
  @@index([category])
  @@map("blog_posts")
}

// ─── Gallery ────────────────────────────────────────────────────
model GalleryAlbum {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String?
  coverUrl    String?
  published   Boolean        @default(true)
  images      GalleryImage[]
  createdAt   DateTime       @default(now())

  @@map("gallery_albums")
}

model GalleryImage {
  id        String       @id @default(cuid())
  url       String
  caption   String?
  order     Int          @default(0)
  albumId   String
  album     GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([albumId])
  @@map("gallery_images")
}

// ─── Daily Devotionals ──────────────────────────────────────────
model Devotional {
  id          String   @id @default(cuid())
  title       String
  scripture   String
  content     String
  author      String
  publishDate DateTime @unique
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([publishDate(sort: Desc)])
  @@map("devotionals")
}

// ─── Prayer Requests ────────────────────────────────────────────
model PrayerRequest {
  id        String   @id @default(cuid())
  name      String
  email     String?
  request   String
  isPrivate Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("prayer_requests")
}

// ─── Notifications ──────────────────────────────────────────────
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("general") // general, event, sermon, blog, community, campaign
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Push Subscriptions ─────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Campaigns (Email/SMS/Push Blasts) ──────────────────────────
model Campaign {
  id          String    @id @default(cuid())
  title       String
  subject     String?   // email subject line
  content     String    // body text or HTML
  channel     String    @default("email") // email, sms, push
  audience    String    @default("all")   // all, members, visitors, ministry group name
  status      String    @default("draft") // draft, scheduled, sent, failed
  scheduledAt DateTime?
  sentAt      DateTime?
  sentCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("campaigns")
}

// ─── Analytics Page Views ───────────────────────────────────────
model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt(sort: Desc)])
  @@map("page_views")
}

// ─── Leadership Groups ─────────────────────────────────────────
// Groups: session, ministers, agents, administration, ministries, departments, committees
model LeadershipGroup {
  id          String               @id @default(cuid())
  name        String               // e.g. "Church Session", "Men's Ministry", "Finance Committee"
  slug        String               @unique
  type        String               // session, ministers, agents, administration, ministry, department, committee
  description String?
  imageUrl    String?
  order       Int                  @default(0)
  isActive    Boolean              @default(true)
  positions   LeadershipPosition[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([type])
  @@index([isActive])
  @@map("leadership_groups")
}

// ─── Leadership Positions ──────────────────────────────────────
// Defines positions within a group (e.g. "Chairman", "Secretary", "Treasurer")
model LeadershipPosition {
  id          String             @id @default(cuid())
  title       String             // e.g. "Chairman", "Secretary", "Youth Pastor"
  description String?
  order       Int                @default(0)
  groupId     String
  group       LeadershipGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  members     LeadershipMember[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([groupId])
  @@map("leadership_positions")
}

// ─── Leadership Members ────────────────────────────────────────
// Tracks current and past members in leadership positions
model LeadershipMember {
  id          String             @id @default(cuid())
  firstName   String
  lastName    String
  title       String?            // e.g. "Elder", "Rev.", "Deaconess"
  email       String?
  phone       String?
  imageUrl    String?
  bio         String?
  startDate   DateTime           // When they started in this position
  endDate     DateTime?          // Null if currently serving
  isCurrent   Boolean            @default(true)
  positionId  String
  position    LeadershipPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([positionId])
  @@index([isCurrent])
  @@index([startDate(sort: Desc)])
  @@map("leadership_members")
}

// =============================================================================
// Page Hero Settings
// =============================================================================

model PageHero {
  id            String   @id @default(cuid())
  pageSlug      String   @unique // e.g., "about", "about/church", "sermons", "contact"
  title         String?  // Optional override for page title
  subtitle      String?  // Optional override for subtitle
  backgroundUrl String?  // Background image URL
  overlayColor  String?  @default("rgba(12, 21, 41, 0.85)") // Dark overlay for text readability
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([pageSlug])
  @@map("page_heroes")
}
