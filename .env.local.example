# =============================================================================
# Environment Variables — copy this file to .env.local and fill in values.
# NEVER commit .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database — Neon PostgreSQL (or any PostgreSQL provider)
# https://console.neon.tech/
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# Stripe — https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) in development, live keys in production.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_<your-stripe-secret-key>
# Optional: expose the publishable key to the browser for Stripe.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_<your-stripe-publishable-key>
# Webhook secret — from Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>

# -----------------------------------------------------------------------------
# Resend — https://resend.com/api-keys
# Used for transactional emails (contact form, newsletter, event reminders)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_<your-resend-api-key>
# "From" address must be verified in your Resend domain settings
RESEND_FROM_EMAIL=noreply@mhtpcaccra.org

# -----------------------------------------------------------------------------
# Admin email — receives contact form notifications
# -----------------------------------------------------------------------------
ADMIN_EMAIL=admin@mhtpcaccra.org

# -----------------------------------------------------------------------------
# mNotify — https://app.mnotify.com/developer
# Ghanaian SMS / bulk-messaging provider used for notifications & reminders.
# -----------------------------------------------------------------------------
MNOTIFY_API_KEY=<your-mnotify-api-key>
# Sender ID approved by mNotify (max 11 characters)
MNOTIFY_SENDER_ID=MHTPC

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://mhtpcaccra.org
